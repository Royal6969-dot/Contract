// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  passwordHash String?
  accounts  Account[]
  sessions  Session[]
  contracts Contract[] @relation("UserContracts")
  participations Participation[]
  evidenceVerifications EvidenceVerification[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Contract {
  id             String           @id @default(cuid())
  title          String
  description    String?
  isGroup        Boolean          @default(false)
  stakeAmountCents Int
  currency       String           @default("USD")
  startDate      DateTime
  endDate        DateTime
  verification   VerificationType @default(PHOTO)
  creatorId      String
  creator        User             @relation("UserContracts", fields: [creatorId], references: [id])
  potCents       Int              @default(0)
  status         ContractStatus   @default(ACTIVE)
  participations Participation[]
  evidences      Evidence[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Participation {
  id           String           @id @default(cuid())
  userId       String
  contractId   String
  hasCompleted Boolean          @default(false)
  depositCents Int              @default(0)
  user         User             @relation(fields: [userId], references: [id])
  contract     Contract         @relation(fields: [contractId], references: [id])
  evidences    Evidence[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Evidence {
  id              String         @id @default(cuid())
  contractId      String
  participationId String
  photoUrl        String?
  note            String?
  latitude        Float?
  longitude       Float?
  createdAt       DateTime       @default(now())
  contract        Contract       @relation(fields: [contractId], references: [id])
  participation   Participation  @relation(fields: [participationId], references: [id])
  verifications   EvidenceVerification[]
}

model EvidenceVerification {
  id         String    @id @default(cuid())
  evidenceId String
  userId     String
  createdAt  DateTime  @default(now())
  evidence   Evidence  @relation(fields: [evidenceId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
  @@unique([evidenceId, userId])
}

enum ContractStatus {
  ACTIVE
  COMPLETED
  FAILED
}

enum VerificationType {
  PHOTO
  FRIEND_CONFIRMATION
}